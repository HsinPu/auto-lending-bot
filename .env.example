# Copy this file to .env and adjust values for your environment.
# Safe defaults use the mock exchange and dry-run mode. For Bitfinex, set EXCHANGE=bitfinex
# and fill EXCHANGE_API_KEY / EXCHANGE_API_SECRET with keys that have no withdrawal permission.
SETTINGS_ENCRYPTION_KEY=
ADMIN_AUTH_TOKEN=
BOT_LABEL=Auto Lending Bot
DISPLAY_TIMEZONE=UTC
BOT_DRY_RUN=true
ALLOW_LIVE_TRADING=false
ALLOW_BALANCE_TRANSFERS=false
BOT_SLEEP_SECONDS=60
BOT_INACTIVE_SLEEP_SECONDS=300
AUTO_REBALANCE_OPEN_OFFERS=false
AUTO_CANCEL_OPEN_OFFERS=false
KEEP_STUCK_ORDERS=true
BOT_MAX_LOOPS=1
RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=30
MARKET_RATE_RETENTION_DAYS=30
MARKET_ANALYSIS_RETENTION_DAYS=30
MARKET_ANALYSIS_CURRENCIES=
MARKET_ANALYSIS_LEVELS=10
MARKET_ANALYSIS_MIN_SAMPLES=0
MARKET_ANALYSIS_MAX_AGE_SECONDS=0
MARKET_ANALYSIS_METHOD=off
MARKET_ANALYSIS_PERCENTILE=75
MARKET_ANALYSIS_MACD_SHORT_SAMPLES=3
MARKET_ANALYSIS_MACD_LONG_SAMPLES=10
MARKET_ANALYSIS_MACD_SHORT_SECONDS=0
MARKET_ANALYSIS_MACD_LONG_SECONDS=0
MARKET_ANALYSIS_MULTIPLIER=1.0
OUTPUT_CURRENCY=BTC
TRANSFERABLE_CURRENCIES=
SMOKE_TEST_CURRENCY=BTC
STRATEGY_DEBUG=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_PREFIX=
NOTIFY_CAUGHT_EXCEPTION=false
NOTIFY_SUMMARY_MINUTES=0
NOTIFY_XDAY_THRESHOLD=false
# Supported: mock, bitfinex. Keep mock until you are ready to read Bitfinex data.
EXCHANGE=mock
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
BITFINEX_ENABLE_LIVE_OFFERS=false
BITFINEX_ENABLE_LIVE_TRANSFERS=false
HTTP_TIMEOUT_SECONDS=30
MIN_DAILY_RATE=0.00005
MAX_DAILY_RATE=0.05
MIN_LOAN_SIZE=0.01
MAX_PERCENT_TO_LEND=100
MAX_TO_LEND=
MAX_TO_LEND_RATE=0
MAX_AMOUNT_TO_LEND=
MAX_ACTIVE_AMOUNT=
MAX_TOTAL_LEND_AMOUNT=
MAX_SINGLE_OFFER_AMOUNT=
MAX_TOTAL_TRANSFER_AMOUNT=
MAX_SINGLE_TRANSFER_AMOUNT=
HIDE_COINS=true
SPREAD_LEND=3
# Supported: off, raw, relative, raw_btc.
GAP_MODE=raw_btc
GAP_BOTTOM=40
GAP_TOP=200
XDAY_THRESHOLD=0
XDAYS=2
XDAY_SPREAD=0
END_DATE=
FRR_AS_MIN=true
FRR_DELTA=0
RATE_OPTIMIZATION_MODE=fill_probability
RATE_OPTIMIZATION_MIN_PROBABILITY=0.25
RATE_OPTIMIZATION_SAMPLE_SIZE=200
# Optional per-currency overrides.
# BTC_MIN_DAILY_RATE=0.00008
# BTC_MIN_LOAN_SIZE=0.02
# BTC_MAX_PERCENT_TO_LEND=80
# BTC_MAX_TO_LEND=0.1
# BTC_MAX_TO_LEND_RATE=0.00008
# BTC_MAX_AMOUNT_TO_LEND=0.1
# BTC_MAX_ACTIVE_AMOUNT=0.5
# BTC_GAP_MODE=raw_btc
# BTC_GAP_BOTTOM=20
# BTC_GAP_TOP=100
# BTC_XDAY_THRESHOLD=0.001
# BTC_XDAYS=30
# BTC_XDAY_SPREAD=2
# BTC_END_DATE=2027-01-15
# BTC_FRR_AS_MIN=false
# BTC_FRR_DELTA=0
# BTC_RATE_OPTIMIZATION_MODE=fill_probability
# BTC_RATE_OPTIMIZATION_MIN_PROBABILITY=0.25
# BTC_RATE_OPTIMIZATION_SAMPLE_SIZE=200
# BITFINEX TIP: confirm observed lendbook rates with STRATEGY_DEBUG=true before live tests.
DATABASE_URL=sqlite:///data/auto_lending_bot.db
LOG_LEVEL=INFO
