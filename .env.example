# Copy this file to .env for local development.
BOT_LABEL=Auto Lending Bot
BOT_DRY_RUN=true
ALLOW_LIVE_TRADING=false
BOT_SLEEP_SECONDS=60
BOT_MAX_LOOPS=1
RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=30
MARKET_RATE_RETENTION_DAYS=30
SMOKE_TEST_CURRENCY=BTC
STRATEGY_DEBUG=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Supported: mock, bitfinex. Use mock by default.
EXCHANGE=mock
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
BITFINEX_ENABLE_LIVE_OFFERS=false
HTTP_TIMEOUT_SECONDS=30
MIN_DAILY_RATE=0.00005
MAX_DAILY_RATE=0.05
MIN_LOAN_SIZE=0.01
MAX_PERCENT_TO_LEND=100
MAX_TO_LEND=
MAX_TO_LEND_RATE=0
MAX_AMOUNT_TO_LEND=
MAX_TOTAL_LEND_AMOUNT=
MAX_SINGLE_OFFER_AMOUNT=
HIDE_COINS=true
SPREAD_LEND=3
GAP_MODE=off
GAP_BOTTOM=0
GAP_TOP=0
XDAY_THRESHOLD=0
XDAYS=2
XDAY_SPREAD=0
FRR_AS_MIN=false
FRR_DELTA=0
# Optional per-currency overrides.
# BTC_MIN_DAILY_RATE=0.00008
# BTC_MIN_LOAN_SIZE=0.02
# BTC_MAX_PERCENT_TO_LEND=80
# BTC_MAX_TO_LEND=0.1
# BTC_MAX_TO_LEND_RATE=0.00008
# BTC_MAX_AMOUNT_TO_LEND=0.1
# BTC_GAP_MODE=raw
# BTC_GAP_BOTTOM=20
# BTC_GAP_TOP=100
# BTC_XDAY_THRESHOLD=0.001
# BTC_XDAYS=30
# BTC_XDAY_SPREAD=2
# BTC_FRR_AS_MIN=false
# BTC_FRR_DELTA=0
# BITFINEX TIP: confirm observed lendbook rates with STRATEGY_DEBUG=true before live tests.
DATABASE_URL=sqlite:///data/auto_lending_bot.db
LOG_LEVEL=INFO
