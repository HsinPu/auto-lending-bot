# Copy this file to .env for local bootstrap.
# Runtime/account settings should usually be managed from the dashboard after startup.

# Bootstrap settings. Keep these in env because the app needs them before reading DB settings.
DATABASE_URL=sqlite:///data/auto_lending_bot.db
SETTINGS_ENCRYPTION_KEY=
ADMIN_AUTH_TOKEN=
LOG_LEVEL=INFO

# Safe fallback settings. The dashboard can override these in SQLite.
EXCHANGE=mock
BOT_DRY_RUN=true
ALLOW_LIVE_TRADING=false
ALLOW_BALANCE_TRANSFERS=false
BOT_MAX_LOOPS=1

# Optional deployment/runtime fallback settings.
DISPLAY_TIMEZONE=UTC
HTTP_TIMEOUT_SECONDS=30
MARKET_RATE_RETENTION_DAYS=30
MARKET_ANALYSIS_RETENTION_DAYS=30

# Profile-owned settings should normally be set in the dashboard/DB.
# Examples if you need temporary env fallback:
# BOT_LABEL=Auto Lending Bot
# EXCHANGE=bitfinex
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=
# BITFINEX_ENABLE_LIVE_OFFERS=false
# BITFINEX_ENABLE_LIVE_TRANSFERS=false
# MAX_TOTAL_LEND_AMOUNT=0
# MAX_SINGLE_OFFER_AMOUNT=0
# MAX_TOTAL_TRANSFER_AMOUNT=
# MAX_SINGLE_TRANSFER_AMOUNT=
# SMOKE_TEST_CURRENCY=BTC
# OUTPUT_CURRENCY=BTC
# MARKET_ANALYSIS_CURRENCIES=BTC,ETH,USDT,USD
# MIN_DAILY_RATE=0.00005
# MAX_DAILY_RATE=0.05
# SPREAD_LEND=0
# MAX_OFFER_AMOUNT=500
# MIN_OFFER_REMAINDER=100
# MIN_OFFER_VALUE_USD=150
# LENDING_RISK_LEVEL=balanced
# GAP_MODE=raw_btc
# GAP_BOTTOM=40
# GAP_TOP=200
# XDAY_THRESHOLD=0.0005479452054794521
# XDAYS=120
# XDAY_SPREAD=0
# ALLOW_ABOVE_MARKET_OFFERS=false
# FRR_AS_MIN=false
# RATE_OPTIMIZATION_MODE=fill_probability
# RATE_OPTIMIZATION_MIN_PROBABILITY=0.10
# RATE_OPTIMIZATION_SAMPLE_SIZE=50

# Live Bitfinex tip: use API keys without withdrawal permissions and verify in dry-run first.
